# Ruby Guide .gitignore

# Ruby specific
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/

# Caching
.cache/
.sass-cache/

# Documentation
.yardoc/
_yardoc/
doc/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup

# Generated files
*.generated
*.compiled

# Database files
*.db
*.sqlite
*.sqlite3

# Configuration files with sensitive data
config/secrets.yml
config/database.yml
config/application.yml

# Node.js (if using for build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Bundler
.bundle/
vendor/bundle/

# RSpec
/spec/examples.txt

# Test coverage
/coverage/

# SimpleCov
.coverage

# RuboCop
.rubocop.yml
.rubocop-*

# Reek
.reek.yml

# Brakeman
brakeman.report

# Security scanner reports
security_report.*

# Performance profiler outputs
profiler_output.*
benchmark_results.*

# Temporary test files
test_temp/
temp_files/

# Generated documentation
docs/generated/
api_docs/

# Build artifacts
build/
dist/
out/

# Package files
*.zip
*.tar.gz
*.rar

# Local development
.local/
dev/
development/

# Experimental features
experimental/
sandbox/

# User-specific files
user_data/
user_config/

# Large binary files
*.exe
*.dll
*.so
*.dylib

# Media files
*.mp4
*.avi
*.mov
*.mp3
*.wav

# Font files
*.ttf
*.otf
*.woff
*.woff2

# Generated certificates
*.pem
*.key
*.crt
*.csr

# Local gem files
*.gemfile.lock

# RVM
.rvmrc
.ruby-version
.ruby-gemset

# rbenv
.ruby-version

# Editor backup files
*~
#*
.#*

# Vim swap files
[._]*.swp
[._]*.swo

# Emacs backup files
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Project specific
# Add any project-specific files or directories here

# Example files that shouldn't be committed
examples/temp/
examples/output/
examples/logs/

# Test databases
test_databases/
sample_data/

# Performance monitoring
performance_logs/
monitoring_data/

# Security test files
security_test_data/
test_credentials.*

# Machine learning models
*.model
*.pkl
*.joblib

# Large datasets
datasets/
large_files/

# Temporary build artifacts
tmp/
temp/

# Local configuration overrides
config/local.*
config/development.local.*
config/test.local.*

# Documentation build artifacts
docs/_build/
docs/.doctrees/

# Jupyter notebooks (if used for examples)
*.ipynb_checkpoints

# Jupyter notebook outputs
*.ipynb

# PyCharm
.idea/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# WebStorm
.idea/

# RubyMine
.idea/

# Local environment overrides
.env.override
.env.local

# Docker
docker-compose.override.yml
docker-compose.local.yml

# Kubernetes
*.local.yml
secrets/

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible
*.retry
inventory/local*

# CI/CD pipeline artifacts
artifacts/
pipeline_cache/

